# IKS AI Assistant - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Google Gemini Configuration (RECOMMENDED - FREE)
# ============================================================
# Get your FREE API key from: https://aistudio.google.com/apikey
# 1,500 requests/day FREE, 1M token context, multimodal
GOOGLE_API_KEY=your-gemini-api-key-here

# ============================================================
# OpenAI Configuration (ALTERNATIVE - PAID)
# ============================================================
# Get your API key from: https://platform.openai.com/api-keys
# $5 minimum, ~$0.001/query
# OPENAI_API_KEY=your-openai-api-key-here

# ============================================================
# Ollama Configuration (ALTERNATIVE - LOCAL, FREE, SLOW)
# ============================================================
# Only needed if using provider: ollama
# OLLAMA_HOST=http://localhost:11434

# ============================================================
# HuggingFace Configuration (for HF Spaces deployment)
# ============================================================
# HF_TOKEN=your-huggingface-token-here

# ============================================================
# Optional: LangSmith for debugging
# ============================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key